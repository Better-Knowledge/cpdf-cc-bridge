# Agente {{NAME}} — variáveis de ambiente (NÃO commitar este arquivo com segredos reais)

# Telegram
TELEGRAM_BOT_TOKEN=          # do BotFather
ALLOWED_USERS=              # ids autorizados, separados por vírgula (DM 1:1)

# Claude Code — login por assinatura (gere com: claude setup-token)
CLAUDE_CODE_OAUTH_TOKEN=

# Bridge tgbridge
BRIDGE_HOOK_SECRET={{HOOK_SECRET}}   # bearer compartilhado hook <-> receiver (gerado)
BRIDGE_HTTP_PORT={{PORT}}            # receiver de hooks (localhost-only)
TMUX_SESSION={{NAME}}                # vazio = deriva do basename do cwd
DEFAULT_PROVIDER={{PROVIDER}}
TZ={{TZ}}

# Monitoramento (avisos de subagente/tarefa no Telegram)
MONITOR_EVENTS=on                    # on | off

# Scheduler — cwd das sessões efêmeras de cron + sentinelas que não postam
AGENT_WORKSPACE=/home/{{NAME}}
SUPPRESS_SENTINELS=NO_NEWS,HEARTBEAT_OK,A2A_DONE
CRON_PERMISSION_MODE=bypassPermissions   # bypassPermissions|acceptEdits|default — evita o cron travar num prompt de
                                         # permissão (ex.: 'set -a; source'). bypass requer container isolado (IS_SANDBOX=1,
                                         # já tratado); regras `deny` e o env-scrub continuam valendo na sessão de cron.
CRON_SESSION_TIMEOUT_MIN=120             # watchdog: encerra a sessão de cron travada após N min e avisa no Telegram
# Modelo das sessões de cron (otimiza custo/cota). Vazio = default do agente. Override por job pelo label:
# CRON_MODEL=sonnet                      # padrão p/ todos os crons (alias do claude --model)
# CRON_MODEL_HEARTBEAT=haiku             # override do job 'heartbeat' (label em MAIÚSCULAS, não-alfanum→_)

# Sessões efêmeras: segredos de infra removidos do ambiente (anti-exfil). Skills lêem de
# /config/bridge.secret. A2A faz scrub completo; cron MANTÉM BRIDGE_HOOK_SECRET (o Stop hook
# precisa dele p/ entregar a saída). Override só se necessário:
# EPHEMERAL_ENV_BLOCKLIST=A2A_SECRET,BRIDGE_HOOK_SECRET,TELEGRAM_BOT_TOKEN   # sessões A2A
# CRON_ENV_BLOCKLIST=A2A_SECRET,TELEGRAM_BOT_TOKEN                           # sessões de cron

# A2A — comunicação entre agentes (requer a rede tgbridge-net)
AGENT_NAME={{NAME}}
A2A_SECRET=                          # vazio = A2A desativado. É o bearer que ESTE agente exige no inbound.
                                     #   Modelo por-agente: cada agente tem um segredo DISTINTO (não compartilhe).
A2A_PEER_SECRETS=                    # segredos dos agentes que VOCÊ chama: 'alvo:segredo,alvo2:segredo2'
                                     #   (= o A2A_SECRET de cada alvo). Vazio → usa o próprio A2A_SECRET (modo compartilhado).
A2A_PORT=8788                        # servidor A2A (0.0.0.0, só na rede compartilhada; não publicar)
A2A_NOTIFY=off                       # avisa no Telegram do destino quando recebe um A2A (auditoria)
A2A_ALLOWED_SENDERS=                 # csv de remetentes; vazio = deriva do agents-registry.json
A2A_RATE_MAX=30                      # máx. de chamadas por remetente na janela
A2A_RATE_WINDOW=300                  # janela do rate-limit (s)

# Integrações de domínio (exemplo — ajuste ao seu agente / .mcp.json)
# MENTORIA_CRM_API_KEY=

# Voz (escolhida no init) — ver HANDOFF-v3.md
VOICE_BACKEND={{VOICE_BACKEND}}      # off | local | openai
{{VOICE_ENV_BLOCK}}
