# Whisper compartilhado
WHISPER_MODEL=small             # tiny|base|small|medium|large-v3
WHISPER_DEVICE=cpu              # cpu | cuda
WHISPER_COMPUTE_TYPE=int8       # int8 (cpu) | float16 (cuda)
WHISPER_LANGUAGE=pt

# Auth (recomendado): exige Authorization: Bearer <WHISPER_SECRET> em /v1/audio/transcriptions.
# Vazio = aberto (compat). Cada agente em modo 'shared' deve setar OPENAI_API_KEY=<este valor>.
WHISPER_SECRET=
